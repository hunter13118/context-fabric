# Context Fabric — environment configuration
# Everything runs offline with mocks by default. Set these only to use a real LLM provider.

# Provider: "mock" (default, no key needed) | "anthropic" | "openai"
CF_AI_PROVIDER=mock

# API key for the chosen real provider (ignored when CF_AI_PROVIDER=mock)
CF_AI_API_KEY=

# Optional model override (defaults chosen per provider)
CF_AI_MODEL=

# Embeddings: "mock" (default, deterministic, offline) | "openai"
CF_EMBED_PROVIDER=mock

# SQLite database path (default: ./data/context-fabric.db; ":memory:" for ephemeral)
CF_DB_PATH=./data/context-fabric.db

# REST API port
CF_API_PORT=8787
