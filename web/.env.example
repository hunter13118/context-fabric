# Clerk publishable key for hunterthemilkman.com (Clerk dashboard → API keys).
# Vite only exposes vars prefixed with VITE_ to the client.
VITE_CLERK_PUBLISHABLE_KEY=pk_live_xxx

# Path the app is served under (must match vite.config base). Leave as-is for
# hunterthemilkman.com/projects/contextfabric.
VITE_BASE_PATH=/projects/contextfabric
